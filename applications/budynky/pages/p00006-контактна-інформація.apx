page 6 (
    name: Контактна інформація
    alias: КОНТАКТНА-ІНФОРМАЦІЯ
    title: Контактна інформація
    pageGroup: @організації
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @admin-or-contributor
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }
    comments {
        comments: Contact info row create/edit dialog launched from the Контактна інформація list on Page 5; TYPE_ID, KIND_ID, and LIST_KIND_ID stay plain numeric inputs because their reference tables are not migrated yet, and delete is limited to ADMIN.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region контактна-інформація (
        name: Контактна інформація
        type: form
        source {
            location: localDatabase
            tableName: RSD_ORGANIZATIONS_CONTACT_INFO
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                t-Region--noBorder
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        comments {
            comments: Single-record form over RSD_ORGANIZATIONS_CONTACT_INFO; the technical FIELD_VALUES column is excluded from editing.
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P6_CITY (
        type: textField
        label {
            label: Місто
            alignment: right
        }
        layout {
            sequence: 90
            region: @контактна-інформація
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        source {
            formRegion: @контактна-інформація
            column: CITY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P6_COUNTRY (
        type: textField
        label {
            label: Країна
            alignment: right
        }
        layout {
            sequence: 70
            region: @контактна-інформація
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        source {
            formRegion: @контактна-інформація
            column: COUNTRY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

