            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        source {
            formRegion: @контактна-інформація
            column: EMAIL_ADDRESS
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P6_ID (
        type: hidden
        layout {
            sequence: 10
            region: @контактна-інформація
            slot: regionBody
        }
        source {
            formRegion: @контактна-інформація
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P6_KIND_ID (
        type: numberField
