            }
            advanced {
                endUserAlias: E
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport pogodzhennya_primary (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn AVTOR (
                sequence: 6
            )

            displayColumn DATA (
                sequence: 2
            )

            displayColumn NAIMENOVANIE (
                sequence: 1
            )

            displayColumn POGODZHUVACHIV (
                sequence: 7
            )

            displayColumn REZULTAT (
                sequence: 5
            )

            displayColumn REZULTATIV (
                sequence: 8
            )

            displayColumn SOSTOYANIE (
