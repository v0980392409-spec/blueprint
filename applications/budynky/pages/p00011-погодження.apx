                heading: Результатів
                alignment: end
            }
            layout {
                sequence: 90
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column SOSTOYANIE (
            type: plainText
            heading {
                heading: Стан
            }
            layout {
